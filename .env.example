# Contentful
CONTENTFUL_SPACE=            # Contentful space ID (Settings → General)
CONTENTFUL_TOKEN=            # Content Delivery API key (Settings → API Keys)

# Email (Gmail SMTP via Nodemailer)
SMTP_USER=                   # Gmail address used for sending
SMTP_PASSWORD=               # Gmail App Password (Google Account → Security → App Passwords)
SMTP_RECIPIENT=              # Email address that receives contact form submissions